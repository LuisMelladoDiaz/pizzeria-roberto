# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Web Push VAPID ───────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY goes here AND in Supabase Edge Function secrets
VITE_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# These go ONLY in Supabase Edge Function secrets (not in .env for the client)
# VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VAPID_EMAIL=admin@pizzeriaroberto.com

# ── Business credentials ─────────────────────────────────────
# Used only to document / seed the Supabase Auth user.
# The actual login is handled by Supabase Auth server-side.
VITE_BUSINESS_EMAIL=roberto@pizzeria.com
VITE_BUSINESS_PASSWORD=your-secure-password-here
